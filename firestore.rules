rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if the user is an admin
    // Admins can be "super-admin", "content-admin" or "admin"
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "super-admin", "content-admin"];
    }

    // Helper: Check if user has active premium
    function isPremiumUser() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.isPremium == true && userData.premiumExpiry > request.time;
    }

    // USERS COLLECTION
    match /users/{userId} {
      // Users can only read their own document
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Allow users to create their own document on signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Allow users to update their own document (for things like name, photoURL)
      // Explicitly disallow updating sensitive fields: role, isPremium, premiumExpiry, referralCode, streak
      allow update: if isAuthenticated() && request.auth.uid == userId
                    && (!request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'isPremium', 'premiumExpiry', 'referralCode', 'streak', 'premiumActivatedAt']));
      allow delete: if false; // Users cannot hard delete themselves
      
      // Admins have full access
      allow read, write: if isAdmin();
    }

    // PAYMENTS COLLECTION
    match /payments/{paymentId} {
      // Only admins and server can read/write payments
      allow read, write: if isAdmin();
    }
    
    // REFERRALS COLLECTION
    match /referrals/{referralId} {
      // Authenticated users can read referrals for attribution tracking
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // CONTENT COLLECTIONS — Public Read for course structure, Admin Write

    match /courses/{courseId} {
      // Anyone can browse courses (even unauthenticated for landing page)
      allow read: if true;
      allow write: if isAdmin();
    }

    match /semesters/{semesterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // RESOURCES — Premium content protection at the database level
    match /resources/{resourceId} {
      // Free resources: anyone authenticated can read
      // Premium resources: only premium users or admins can read
      allow read: if isAuthenticated() && (
        resource.data.isPremium == false || 
        isPremiumUser() || 
        isAdmin()
      );
      // Allow unauthenticated to read non-premium resource metadata 
      // (for SEO / listing purposes — the actual content URL is protected)
      allow read: if !isAuthenticated() && resource.data.isPremium == false;
      allow write: if isAdmin();
    }

    // DAILY QUESTIONS
    match /dailyQuestions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // USER PROGRESS — users can read/write only their own progress
    match /userProgress/{progressId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() 
                   && (resource == null || resource.data.userId == request.auth.uid)
                   && request.resource.data.userId == request.auth.uid;
    }

    // ANALYTICS — write-only from authenticated clients
    match /analytics/{eventId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // DONATIONS
    match /donations/{donationId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    
    // CATCH-ALL (Deny everything else)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
